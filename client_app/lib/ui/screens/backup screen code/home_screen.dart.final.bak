// ─────────────────────────────────────────────
//  Screen
// ─────────────────────────────────────────────

class HomeScreen extends StatefulWidget {
  const HomeScreen({super.key});

  @override
  State<HomeScreen> createState() => _HomeScreenState();
}

class _HomeScreenState extends State<HomeScreen> {
  // ── Identitas siswa (bisa diganti dari session/auth nanti) ──
  static const String _namaRole    = 'Siswa';
  static const String _namaJurusan = 'RPL';

  String _selectedProgress = 'Semua progres';
  bool _isDarkMode = false;
  final TextEditingController _searchController = TextEditingController();

  // Filter modul berdasarkan jurusan siswa
  List<ModuleItem> get _filteredModules {
    final targetKategori = _kJurusanKategori[_namaJurusan];
    // Jika kode jurusan tidak dikenal, tampilkan semua
    if (targetKategori == null) return _kModules;
    return _kModules
        .where((m) => m.category == targetKategori)
        .toList();
  }

  @override
  void dispose() {
    _searchController.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    final modules = _filteredModules;

    return Scaffold(
      backgroundColor: _AppColors.background,
      body: SafeArea(
        child: CustomScrollView(
          physics: const BouncingScrollPhysics(),
          slivers: [
            _SliverAppBar(
              isDarkMode: _isDarkMode,
              onToggleDarkMode: () =>
                  setState(() => _isDarkMode = !_isDarkMode),
              namaRole: _namaRole,
              namaJurusan: _namaJurusan,
            ),
            SliverToBoxAdapter(
              child: Padding(
                padding: const EdgeInsets.fromLTRB(16, 24, 16, 0),
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    const _WelcomeSection(),
                    const SizedBox(height: 20),
                    const _ContinueLearningCard(),
                    const SizedBox(height: 28),
                    const _SectionHeader(
                      title: 'Modul Pembelajaran',
                      subtitle:
                          'Cari, filter, dan pilih modul untuk mulai belajar',
                    ),
                    const SizedBox(height: 16),
                    _SearchBar(controller: _searchController),
                    const SizedBox(height: 12),
                    _FilterChipRow(
                      items: _kProgressFilters,
                      selected: _selectedProgress,
                      activeColor: _AppColors.progressFilter,
                      onTap: (val) =>
                          setState(() => _selectedProgress = val),
                    ),
                    const SizedBox(height: 16),
                  ],
                ),
              ),
            ),

            // ── Grid modul (hanya jurusan siswa) ──
            if (modules.isEmpty)
              const SliverToBoxAdapter(child: _EmptyModuleState())
            else
              SliverPadding(
                padding: const EdgeInsets.fromLTRB(16, 0, 16, 24),
                sliver: SliverGrid(
                  gridDelegate:
                      const SliverGridDelegateWithFixedCrossAxisCount(
                    crossAxisCount: 2,
                    crossAxisSpacing: 12,
                    mainAxisSpacing: 12,
                    childAspectRatio: 0.72,
                  ),
                  delegate: SliverChildBuilderDelegate(
                    (context, i) => _ModuleCard(module: modules[i]),
                    childCount: modules.length,
                  ),
                ),
              ),
          ],
        ),
      ),
    );
  }
}

// ─────────────────────────────────────────────
//  Sliver App Bar
// ─────────────────────────────────────────────

class _SliverAppBar extends StatelessWidget {
  const _SliverAppBar({
    required this.isDarkMode,
