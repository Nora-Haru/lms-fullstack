  static const textPrimary = Color(0xFF1E293B);
  static const textSecondary = Color(0xFF64748B);
  static const textMuted = Color(0xFF94A3B8);
  static const border = Color(0xFFE2E8F0);
  static const chipBorder = Color(0xFFCBD5E1);
  static const progressBg = Color(0xFFE2E8F0);
  static const badgeBg = Color(0xFFFEF3C7);
  static const badgeText = Color(0xFFD97706);
  static const progressFilter = Color(0xFFEF6C00);
  static const gradeChip = Color(0xFFF1F5F9);
  static const gradeChipText = Color(0xFF475569);
}

